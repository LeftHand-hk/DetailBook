generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  businessName     String
  name             String
  phone            String   @default("")
  city             String   @default("")
  slug             String   @unique
  plan             String   @default("starter")
  trialEndsAt      String   @default("")
  bio              String?  @db.Text
  address          String?
  logo             String?  @db.Text
  coverImage       String?  @db.Text
  instagram        String?
  facebook         String?
  website          String?
  rating           Float?
  reviewCount      Int?
  yearsInBusiness  Int?
  serviceAreas     Json?
  businessHours    Json?
  emailReminders   Boolean  @default(true)
  customMessage    String?  @db.Text
  advanceBookingDays Int    @default(30)

  bannerImage          String?  @db.Text
  bannerOverlayOpacity Int      @default(60)
  serviceLayout        String   @default("cards")
  bookingPageTheme     String   @default("light")
  accentColor          String   @default("#3B82F6")
  bookingPageTitle     String?
  bookingPageSubtitle  String?
  showRating           Boolean  @default(true)
  showSocialLinks      Boolean  @default(true)
  showServiceAreas     Boolean  @default(true)
  showBusinessHours    Boolean  @default(true)
  showTrustBadges      Boolean  @default(true)
  requireDeposit       Boolean  @default(false)
  depositPercentage    Int      @default(20)
  thankYouMessage      String?  @db.Text
  termsText            String?  @db.Text

  smsTemplates   Json?
  emailTemplates Json?
  paymentMethods Json?

  serviceType  String   @default("mobile")

  // IANA timezone of the business (e.g. "America/Los_Angeles"). Used for
  // formatting emails/SMS, calendar availability, and booking time slots.
  timezone     String   @default("America/New_York")

  suspended            Boolean  @default(false)
  promoCodeUsed        String?
  promoDiscount        Float?
  paddleCustomerId     String?
  paddleSubscriptionId String?
  subscriptionStatus   String?

  googleAccessToken    String?  @db.Text
  googleRefreshToken   String?  @db.Text
  googleCalendarId     String?
  googleCalendarEnabled Boolean @default(false)

  // Notification settings
  emailConfirmations    Boolean @default(true)
  smsConfirmations      Boolean @default(true)
  smsRemindersEnabled   Boolean @default(true)
  emailRemindersEnabled Boolean @default(true)

  // Updated on login and on every authenticated session check
  // (/api/auth/me). Used by the admin dashboard to surface
  // active vs inactive accounts.
  lastLoginAt DateTime?

  // Captured at signup from request headers (Netlify edge adds
  // x-country / x-nf-client-connection-ip). Used by admin to know
  // which country an account signed up from. Never shown to the user.
  signupIp      String?
  signupCountry String?  // ISO-3166 alpha-2 (e.g. "US", "DE", "AL")

  // Setup tour state. The tour is a 5-step modal in /dashboard guiding the
  // user through post-signup configuration. `dismissed` hides the auto-open
  // (user can still reopen from the floating "Setup" button); `completedAt`
  // is set when all steps are done so the button hides entirely. `progress`
  // stores manual flags (e.g. booking_link_shared) that can't be derived
  // from row data alone.
  onboardingDismissed   Boolean   @default(false)
  onboardingCompletedAt DateTime?
  onboardingProgress    Json?

  // Welcome email sequence (4 emails: Day 0, Day 2, Day 5, Day 13). Each
  // *At column is the timestamp of decision (sent OR explicitly skipped).
  // For Day 2 in particular, `welcomeEmailDay2Skipped` distinguishes
  // "we decided not to send because the user already has packages" from
  // "we sent it" — both set welcomeEmailDay2At.
  //
  // `welcomeEmailsPaused` is flipped true when the user clicks the
  // unsubscribe link; once paused no more emails in the sequence go out.
  // `welcomeUnsubToken` is the random token embedded in the unsub URL.
  //
  // `welcomeEmailsSent` / `welcomeEmailLastSentAt` are kept temporarily
  // for back-compat with old admin views; new code reads the per-email
  // *At columns instead.
  welcomeEmailDay0At      DateTime?
  welcomeEmailDay2At      DateTime?
  welcomeEmailDay2Skipped Boolean   @default(false)
  welcomeEmailDay5At      DateTime?
  welcomeEmailDay13At     DateTime?
  welcomeEmailsSent       Int       @default(0)
  welcomeEmailLastSentAt  DateTime?
  welcomeEmailsPaused     Boolean   @default(false)
  welcomeUnsubToken       String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packages Package[]
  bookings Booking[]
  staff    Staff[]
  supportTickets SupportTicket[]
  notifications Notification[]
  emailLogs EmailLog[]

  @@index([email])
  @@index([slug])
  @@index([createdAt])
  @@index([lastLoginAt])
}

// Audit log for every transactional email we attempt to send. One row
// per attempt (a 3-retry send writes 3 rows so debugging which attempt
// finally succeeded is straightforward). `success=false` rows let us
// detect SMTP outages from the admin UI without scraping server logs.
model EmailLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // e.g. "welcome_day0", "welcome_day2", "welcome_day5", "welcome_day13"
  emailType    String
  // The address we actually sent to (may differ from user.email for the
  // admin "test sequence" button which mails the admin).
  recipient    String
  success      Boolean  @default(false)
  errorMessage String?  @db.Text
  // 1, 2, 3 for the three retry attempts in a single send call.
  attempt      Int      @default(1)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([emailType])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // booking_new | booking_cancelled | deposit_paid | system
  title     String
  message   String   @db.Text
  bookingId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model SupportTicket {
  id           String   @id @default(cuid())
  subject      String
  message      String   @db.Text
  category     String   @default("general")
  priority     String   @default("normal") // normal | priority
  status       String   @default("open")   // open | in_progress | resolved | closed
  adminReply   String?  @db.Text
  repliedAt    DateTime?
  adminUnread  Boolean  @default(true)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  TicketMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    String        // "user" | "admin"
  content   String        @db.Text
  createdAt DateTime      @default(now())
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  discountType  String    @default("percent")
  discountValue Float
  appliesTo     String    @default("both")
  maxUses       Int?
  usedCount     Int       @default(0)
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
}

model Package {
  id          String  @id @default(cuid())
  name        String
  description String  @db.Text
  price       Float
  duration    Int
  deposit     Float?
  active      Boolean @default(true)

  // Optional list of paid extras the customer can tick on top of the
  // base package (e.g. "Engine bay clean +$25", "Pet hair removal +$15").
  // Stored as Json (not a separate model) because addons live and die
  // with the package — there's no need to query them independently and
  // the array stays small (typically 0-10 entries).
  // Shape: [{ id: string, name: string, price: number, duration?: number }]
  addons Json?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String   @default("")
  role      String   @default("detailer")
  color     String   @default("#3B82F6")
  active    Boolean  @default(true)
  avatar    String?  @db.Text
  password  String   @default("")
  notes     String?  @db.Text

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Booking {
  id              String @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String
  vehicleMake     String
  vehicleModel    String
  vehicleYear     String
  vehicleColor    String
  serviceId       String
  serviceName     String
  servicePrice    Float
  date            String
  time            String
  status          String @default("pending")
  depositPaid     Float  @default(0)
  depositRequired Float  @default(0)
  notes           String? @db.Text
  address         String?
  paymentMethod   String  @default("")
  paymentProof    String? @db.Text

  reminderSentAt DateTime?

  // Snapshot of paid extras the customer ticked at booking time. We store
  // a copy (not a FK to Package.addons) so the booking row stays correct
  // if the owner later edits or deletes the addon definition.
  // Shape: [{ id: string, name: string, price: number, duration?: number }]
  selectedAddons Json?
  // Sum of selectedAddons[].price, denormalised for fast dashboard
  // aggregation (revenue per booking) without parsing the JSON each time.
  // The customer's grand total is servicePrice + addonsTotal.
  addonsTotal     Float    @default(0)

  staffId   String?
  staff     Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model PlatformSettings {
  id                   String  @id @default("default")
  platformName         String  @default("DetailBook")
  supportEmail         String  @default("support@detailbook.com")
  defaultDomain        String  @default("detailbook.app")
  customDomainsEnabled Boolean @default(true)
  starterPrice         Float   @default(29)
  proPrice             Float   @default(49)
  trialDays            Int     @default(30)
  maintenanceMode      Boolean @default(false)
  maintenanceMessage   String? @db.Text
  dbHost               String  @default("localhost")
  dbPort               Int     @default(3306)
  dbName               String  @default("detailbook")
  dbUser               String  @default("root")
  dbPassword           String  @default("")

  stripeEnabled        Boolean @default(false)
  stripePublishableKey String?
  stripeSecretKey      String?
  stripeWebhookSecret  String?
  cryptoEnabled        Boolean @default(false)
  cryptoWalletAddress  String?
  cryptoNetwork        String?
  cryptoAcceptedCoins  Json?

  updatedAt DateTime @updatedAt
}
